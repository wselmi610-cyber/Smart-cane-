<resources>
    <style name="Theme.SmartCane" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Black background everywhere -->
        <item name="android:windowBackground">@android:color/black</item>
        <item name="colorPrimary">@android:color/black</item>
        <item name="colorPrimaryVariant">@android:color/black</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSurface">@android:color/black</item>
        <item name="colorOnSurface">@android:color/white</item>
        <!-- Force dark mode always (accessibility) -->
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <style name="Theme.SmartCane.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.SmartCane</item>
    </style>
</resources>