<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- ── TOP AMBER ACCENT BAR ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/amber_primary" />

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- Back arrow -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/amber_primary"
            android:textSize="26sp"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true"
            android:id="@+id/btnFamilyBack"
            android:contentDescription="Go back to home screen button" />

        <!-- Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Family Contacts"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Count badge -->
        <TextView
            android:id="@+id/tvContactCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 contacts"
            android:textColor="@color/amber_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_pill_amber"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

    </LinearLayout>

    <!-- ── STATUS BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_amber_tint"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/tvFamilyStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Say a name to call, or say Add contact"
            android:textColor="@color/status_listening"
            android:textSize="13sp"
            android:gravity="center" />

        <!-- Listening indicator -->
        <TextView
            android:id="@+id/tvFamilyListening"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎤 Listening..."
            android:textColor="@color/teal_primary"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ── CONTACT LIST ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- ── EMPTY STATE ── -->
    <LinearLayout
        android:id="@+id/tvEmptyContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👥"
            android:textSize="56sp"
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No contacts yet"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Say 'Add contact' to add one"
            android:textColor="@color/text_disabled"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- ── BOTTOM BUTTONS ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:paddingTop="8dp">

        <!-- Add Contact -->
        <Button
            android:id="@+id/btnAddContact"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="10dp"
            android:text="＋  Add Contact"
            android:textColor="@color/text_on_accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/amber_primary"
            android:contentDescription="Add new family contact button" />

    </LinearLayout>

</LinearLayout>