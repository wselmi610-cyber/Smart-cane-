<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page"
    android:padding="20dp">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Cane icon + title block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Cane icon placeholder -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🦯"
                android:textSize="28sp"
                android:paddingEnd="10dp"
                android:rotation="-30" />

            <!-- Title + subtitle -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smart Cane"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice Assistant"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

            </LinearLayout>
        </LinearLayout>

        <!-- Connected status pill -->
        <TextView
            android:id="@+id/tvCaneStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Connected"
            android:textColor="@color/status_success"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_status_pill_green"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:contentDescription="Smart cane connection status" />

    </LinearLayout>

    <!-- ── NAVIGATE BUTTON ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnNavigate"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Navigate button. Opens voice navigation."
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Left teal accent bar -->
            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/teal_primary"
                android:layout_marginEnd="16dp" />

            <!-- Teal icon circle -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_circle_teal"
                android:layout_marginEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🧭"
                    android:textSize="22sp" />

            </FrameLayout>

            <!-- Label -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Navigate"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Chevron -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── FAMILY CONTACTS BUTTON ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnFamily"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Family contacts button. Opens your contact list."
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Left amber accent bar -->
            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/amber_primary"
                android:layout_marginEnd="16dp" />

            <!-- Amber icon circle -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_circle_amber"
                android:layout_marginEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="👨‍👩‍👧"
                    android:textSize="22sp" />

            </FrameLayout>

            <!-- Label -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Family Contacts"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Chevron -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── HISTORY BUTTON ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="History button. Opens your trip history."
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Left lavender accent bar -->
            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/lavender_primary"
                android:layout_marginEnd="16dp" />

            <!-- Lavender icon circle -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_circle_lavender"
                android:layout_marginEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🕐"
                    android:textSize="22sp" />

            </FrameLayout>

            <!-- Label -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="History"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Chevron -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── BATTERY LEVEL BUTTON ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnBattery"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Battery level button. Reads battery status."
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Left blue accent bar -->
            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/blue_primary"
                android:layout_marginEnd="16dp" />

            <!-- Blue icon circle -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_circle_blue"
                android:layout_marginEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🔋"
                    android:textSize="22sp" />

            </FrameLayout>

            <!-- Label -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Battery Level"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Chevron -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── LISTENING INDICATOR ── -->
    <LinearLayout
        android:id="@+id/layoutListening"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_listening_bar"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎤"
            android:textSize="16sp"
            android:paddingEnd="8dp" />

        <TextView
            android:id="@+id/tvListeningLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Listening..."
            android:textColor="@color/status_listening"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>