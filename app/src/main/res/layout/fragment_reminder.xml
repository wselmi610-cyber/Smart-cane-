<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- ── TOP TEAL ACCENT BAR ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/teal_primary" />

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- Back arrow -->
        <TextView
            android:id="@+id/btnReminderBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/teal_primary"
            android:textSize="26sp"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Go back to home screen button" />

        <!-- Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⏰ Reminders"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Count badge -->
        <TextView
            android:id="@+id/tvReminderCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 reminders"
            android:textColor="@color/teal_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_status_pill_green"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

    </LinearLayout>

    <!-- ── STATUS BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/tvReminderStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Say ADD, LIST, or BACK"
            android:textColor="@color/status_listening"
            android:textSize="13sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvReminderListening"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎤 Listening..."
            android:textColor="@color/teal_primary"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ── REMINDER LIST ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvReminders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- ── EMPTY STATE ── -->
    <LinearLayout
        android:id="@+id/layoutEmptyReminders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰"
            android:textSize="56sp"
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No reminders yet"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Say 'Add' to create one"
            android:textColor="@color/text_disabled"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- ── BOTTOM BUTTON ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:paddingTop="8dp">

        <Button
            android:id="@+id/btnAddReminder"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="＋  Add Reminder"
            android:textColor="@color/text_on_accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/teal_primary"
            android:contentDescription="Add new reminder button" />

    </LinearLayout>

</LinearLayout>